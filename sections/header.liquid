    },
    {
      "type": "color",
      "id": "bg_bar_info_normal",
      "label": "Texto",
      "default": "#515971"
    },
    {
      "type": "header",
      "content": "Barra colorida"
    },
    {
      "type": "checkbox",
      "id": "mostrar_barra",
      "label": "Mostrar barra",
      "default": true
    },
    {
      "type": "color",
      "id": "background1",
