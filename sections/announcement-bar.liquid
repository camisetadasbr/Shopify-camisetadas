{%- if section.settings.show_announcement -%}
  <section data-section-id="{{ section.id }}" data-section-type="announcement-bar">
    <div class="announcement-bar">
      <div class="container">
        <div class="announcement-bar__inner">
          <div class="announcement-bar__message-container">
            <div class="announcement-bar__message-track">
              {%- for block in section.blocks -%}
                <div class="announcement-bar__message" {{ block.shopify_attributes }}>
                  {%- if block.settings.link != blank -%}
                    <a href="{{ block.settings.link }}" class="announcement-bar__link">
                  {%- endif -%}

                  <span>{{ block.settings.text }}</span>

                  {%- if block.settings.link != blank -%}
                    </a>
                  {%- endif -%}
                </div>
              {%- endfor -%}
              
              {%- comment -%} Duplicate blocks for infinite scroll if there are enough items {%- endcomment -%}
              {%- if section.blocks.size > 1 -%}
                {%- for block in section.blocks -%}
                  <div class="announcement-bar__message announcement-bar__message--duplicate">
                    {%- if block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}" class="announcement-bar__link">
                    {%- endif -%}

                    <span>{{ block.settings.text }}</span>

                    {%- if block.settings.link != blank -%}
                      </a>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .announcement-bar {
      background-image: linear-gradient(to right, {{ section.settings.background1 }}, {{ section.settings.background2 }});
      color: {{ section.settings.text_color }};
      overflow: hidden;
      padding: 10px 0;
      position: relative;
    }

    .announcement-bar__message-container {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
    }

    .announcement-bar__message-track {
      display: flex;
      white-space: nowrap;
      {%- if section.blocks.size > 1 -%}
        animation: announcement-scroll {{ section.settings.scrolling_speed }}s linear infinite;
      {%- endif -%}
    }

    .announcement-bar__message {
      padding: 0 50px;
      flex-shrink: 0;
      font-size: 14px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .announcement-bar__link {
      color: inherit;
      text-decoration: none;
    }

    @keyframes announcement-scroll {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }

    /* Pause on hover if desired */
    .announcement-bar:hover .announcement-bar__message-track {
      animation-play-state: paused;
    }

    @media screen and (max-width: 640px) {
      .announcement-bar__message {
        padding: 0 30px;
        font-size: 12px;
      }
    }
  </style>

  <script>
    document.documentElement.style.setProperty('--announcement-bar-height', document.getElementById('shopify-section-{{ section.id }}').clientHeight + 'px');
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Barra de anúncio",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Mostrar barra de anúncio",
      "default": true
    },
    {
      "type": "color",
      "id": "background1",
      "label": "Cor 1",
      "default": "#1e2d7d"
    },
    {
      "type": "color",
      "id": "background2",
      "label": "Cor 2",
      "default": "#1e2d7d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Texto",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "scrolling_speed",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "s",
      "label": "Velocidade do scroll (segundos)",
      "default": 15
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Anúncio",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Announce something here"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement",
        "settings": {
          "text": "parcelamento em 12x + frete gratis"
        }
      },
      {
        "type": "announcement",
        "settings": {
          "text": "CONFIRA NOSSAS NOVIDADES!"
        }
      }
    ]
  }
}
{% endschema %}
 %}