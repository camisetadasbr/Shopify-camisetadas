<section class="section" data-section-id="{{ section.id }}" data-section-type="tabbed-collections">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <header class="section__header">
        <h2 class="section__title heading h3">{{ section.settings.title | escape }}</h2>
      </header>
    {%- endif -%}

    <div class="tabbed-collections">
      <div class="tabs-nav">
        <ul class="tabs-nav__list">
          {%- for block in section.blocks -%}
            {%- assign collection = collections[block.settings.collection] -%}
            <li class="tabs-nav__item" {{ block.shopify_attributes }}>
              <button class="tabs-nav__button {% if forloop.first %}is-active{% endif %}" 
                      data-tab-target="tab-{{ section.id }}-{{ forloop.index }}"
                      aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
                {%- if collection != blank -%}
                  {{ block.settings.title | default: collection.title | escape }}
                {%- else -%}
                  Aba {{ forloop.index }}
                {%- endif -%}
              </button>
            </li>
          {%- endfor -%}

          {%- if section.blocks.size == 0 and request.design_mode -%}
            <li class="tabs-nav__item">
              <button class="tabs-nav__button is-active">Clique em "Adicionar Coleção"</button>
            </li>
          {%- endif -%}
        </ul>
      </div>

      <div class="tabs-content">
        {%- for block in section.blocks -%}
          {%- assign collection = collections[block.settings.collection] -%}
          <div id="tab-{{ section.id }}-{{ forloop.index }}" 
               class="tab-panel {% if forloop.first %}is-visible{% endif %}"
               {% unless forloop.first %}style="display: none;"{% endunless %}
               {{ block.shopify_attributes }}>
            
            {%- if collection != blank -%}
              {%- if block.settings.image != blank -%}
                <a href="{{ collection.url }}" class="tab-panel__image-wrapper" rel="noopener" data-no-instant>
                  <div class="aspect-ratio">
                    <img class="tab-panel__image lazyload image--fade-in" 
                         data-src="{{ block.settings.image | img_url: '600x600', crop: 'center' }}" 
                         alt="{{ block.settings.image.alt | escape }}">
                  </div>
                </a>
              {%- elsif request.design_mode -%}
                 <div class="tab-panel__placeholder" style="text-align: center; padding: 60px; border: 2px dashed #ccc;">
                  <p>Esta aba não tem imagem. Carregue uma "Imagem da Coleção" no menu lateral.</p>
                </div>
              {%- endif -%}
            {%- elsif request.design_mode -%}
              <div class="tab-panel__placeholder" style="text-align: center; padding: 40px; border: 2px dashed #ccc;">
                <p>Esta aba está vazia. Selecione uma coleção nas configurações do bloco à esquerda.</p>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}

        {%- if section.blocks.size == 0 and request.design_mode -%}
          <div class="section-placeholder" style="text-align: center; padding: 60px; border: 2px dashed #ccc; background: #f9f9f9;">
            <h3 class="heading h3">Configuração Necessária</h3>
            <p>Adicione blocos de "Coleção" no menu lateral para começar a exibir seus produtos aqui.</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .tabbed-collections {
    margin-top: 30px;
  }

  .tabs-nav {
    border-bottom: 2px solid #e1e3e4;
    margin-bottom: 30px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .tabs-nav__list {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    white-space: nowrap;
  }

  .tabs-nav__button {
    background: none;
    border: none;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: 600;
    color: #677279;
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tabs-nav__button:hover {
    color: var(--accent-color);
  }

  .tabs-nav__button.is-active {
    color: var(--accent-color);
  }

  .tabs-nav__button.is-active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--accent-color);
  }

  .tab-panel__image-wrapper {
    display: block;
    margin: 0 auto;
    max-width: 600px; /* Alinhado com a recomendação da seção de Coleções */
    border-radius: var(--border-radius-theme);
    overflow: hidden;
    position: relative;
  }

  .tab-panel__image-wrapper .aspect-ratio {
    position: relative;
    padding-bottom: 100%; /* Proporção 1:1 igual às Coleções */
    height: 0;
  }

  .tab-panel__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media screen and (max-width: 640px) {
    .tab-panel__image-wrapper {
      margin-bottom: 20px;
    }
  }

  .section__footer {
    text-align: center;
    margin-top: 40px;
  }
</style>

<script>
  (function() {
    function initTabs() {
      const section = document.querySelector('[data-section-id="{{ section.id }}"]');
      if (!section) return;

      const tabButtons = section.querySelectorAll('.tabs-nav__button');
      const tabPanels = section.querySelectorAll('.tab-panel');

      tabButtons.forEach(button => {
        button.addEventListener('click', () => {
          const targetId = button.getAttribute('data-tab-target');
          const targetPanel = section.querySelector(`#${targetId}`);

          if (!targetPanel) return;

          // Desativar todos
          tabButtons.forEach(btn => {
            btn.classList.remove('is-active');
            btn.setAttribute('aria-expanded', 'false');
          });
          tabPanels.forEach(panel => {
            panel.classList.remove('is-visible');
            panel.style.display = 'none';
          });

          // Ativar selecionado
          button.classList.add('is-active');
          button.setAttribute('aria-expanded', 'true');
          targetPanel.style.display = 'block';
          
          // Trigger lazyload if theme uses it
          window.dispatchEvent(new Event('resize'));
        });
      });
    }

    // Inicialização segura
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabs);
    } else {
      initTabs();
    }

    // Suporte ao editor da Shopify
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initTabs();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "⭐ Coleções em Abas ⭐",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título da Seção",
      "default": "Nossas Coleções"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Coleção",
      "limit": 20,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Coleção"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem da Coleção",
          "info": "Banner opcional para aparecer acima dos produtos."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título da Aba",
          "info": "Se vazio, usa o nome da coleção."
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Collection",
      "name": "Coleções em Abas",
      "blocks": [
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
