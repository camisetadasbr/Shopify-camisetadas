<section class="section" data-section-id="{{ section.id }}" data-section-type="tabbed-collections">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <header class="section__header">
        <h2 class="section__title heading h3">{{ section.settings.title | escape }}</h2>
      </header>
    {%- endif -%}

    <div class="tabbed-collections">

      {%- comment -%}
        BOTÕES DE NAVEGAÇÃO — cada um é um <a> direto para a coleção.
        NÃO usam JavaScript de troca de painel para não quebrar o histórico do navegador.
      {%- endcomment -%}
      <div class="tabs-nav">
        <ul class="tabs-nav__list">
          {%- for block in section.blocks -%}
            {%- assign collection = collections[block.settings.collection] -%}
            <li class="tabs-nav__item" {{ block.shopify_attributes }}>
              {%- if collection != blank -%}
                <a href="{{ collection.url }}"
                   class="tabs-nav__button"
                   rel="noopener">
                  {{ block.settings.title | default: collection.title | escape }}
                </a>
              {%- else -%}
                <span class="tabs-nav__button tabs-nav__button--empty">
                  Aba {{ forloop.index }}
                </span>
              {%- endif -%}
            </li>
          {%- endfor -%}

          {%- if section.blocks.size == 0 and request.design_mode -%}
            <li class="tabs-nav__item">
              <span class="tabs-nav__button">Clique em "Adicionar Coleção"</span>
            </li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%}
        BANNERS DAS COLEÇÕES — exibidos em grade.
        Cada banner é um <a> limpo apontando direto para a coleção, sem scripts.
      {%- endcomment -%}
      <div class="tabs-content tabs-content--grid">
        {%- for block in section.blocks -%}
          {%- assign collection = collections[block.settings.collection] -%}

          {%- if collection != blank and block.settings.image != blank -%}
            <a href="{{ collection.url }}"
               class="tab-panel__image-wrapper"
               rel="noopener"
               title="{{ block.settings.title | default: collection.title | escape }}">
              <div class="aspect-ratio">
                <img class="tab-panel__image lazyload image--fade-in"
                     data-src="{{ block.settings.image | img_url: '600x600', crop: 'center' }}"
                     alt="{{ block.settings.image.alt | default: collection.title | escape }}">
              </div>
              <span class="tab-panel__label">{{ block.settings.title | default: collection.title | escape }}</span>
            </a>

          {%- elsif request.design_mode -%}
            <div class="tab-panel__placeholder" style="text-align:center; padding:40px; border:2px dashed #ccc;">
              {%- if collection == blank -%}
                <p>Aba {{ forloop.index }}: selecione uma coleção no menu lateral.</p>
              {%- else -%}
                <p>Coleção "{{ collection.title }}": carregue uma imagem no menu lateral.</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if section.blocks.size == 0 and request.design_mode -%}
          <div class="section-placeholder" style="text-align:center; padding:60px; border:2px dashed #ccc; background:#f9f9f9;">
            <h3 class="heading h3">Configuração Necessária</h3>
            <p>Adicione blocos de "Coleção" no menu lateral para começar a exibir seus produtos aqui.</p>
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

<style>
  /* ===== NAVEGAÇÃO ===== */
  .tabbed-collections {
    margin-top: 30px;
  }

  .tabs-nav {
    border-bottom: 2px solid #e1e3e4;
    margin-bottom: 30px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .tabs-nav__list {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    white-space: nowrap;
  }

  /* Links de navegação (antes eram <button>, agora são <a>) */
  .tabs-nav__button {
    display: inline-block;
    text-decoration: none;
    background: none;
    border: none;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: 600;
    color: #677279;
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tabs-nav__button:hover {
    color: var(--accent-color);
    text-decoration: none;
  }

  .tabs-nav__button--empty {
    cursor: default;
    opacity: 0.5;
  }

  /* ===== GRADE DE BANNERS ===== */
  .tabs-content--grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  @media screen and (max-width: 640px) {
    .tabs-content--grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  /* ===== CARD / BANNER ===== */
  .tab-panel__image-wrapper {
    display: block;
    border-radius: var(--border-radius-theme);
    overflow: hidden;
    position: relative;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .tab-panel__image-wrapper:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }

  .tab-panel__image-wrapper .aspect-ratio {
    position: relative;
    padding-bottom: 100%;
    height: 0;
    overflow: hidden;
  }

  .tab-panel__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .tab-panel__image-wrapper:hover .tab-panel__image {
    transform: scale(1.05);
  }

  /* Label sobre o banner */
  .tab-panel__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, transparent 100%);
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
  }
</style>

{% schema %}
{
  "name": "⭐ Coleções em Abas ⭐",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título da Seção",
      "default": "Nossas Coleções"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Coleção",
      "limit": 20,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Coleção"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagem da Coleção",
          "info": "Banner que aparece na grade de categorias."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título da Aba / Banner",
          "info": "Se vazio, usa o nome da coleção."
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Collection",
      "name": "Coleções em Abas",
      "blocks": [
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
