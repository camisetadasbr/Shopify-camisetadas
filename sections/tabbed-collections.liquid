<section class="section" data-section-id="{{ section.id }}" data-section-type="tabbed-collections">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <header class="section__header">
        <h2 class="section__title heading h3">{{ section.settings.title | escape }}</h2>
      </header>
    {%- endif -%}

    <div class="tabbed-collections">
      <div class="tabs-nav">
        <ul class="tabs-nav__list">
          {%- for block in section.blocks -%}
            {%- assign collection = collections[block.settings.collection] -%}
            {%- if collection != blank -%}
              <li class="tabs-nav__item">
                <button class="tabs-nav__button {% if forloop.first %}is-active{% endif %}" 
                        data-tab-target="tab-{{ section.id }}-{{ forloop.index }}"
                        aria-expanded="{% if forloop.first %}true{% else %}false{% endif %}">
                  {{ block.settings.title | default: collection.title | escape }}
                </button>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div class="tabs-content">
        {%- for block in section.blocks -%}
          {%- assign collection = collections[block.settings.collection] -%}
          {%- if collection != blank -%}
            <div id="tab-{{ section.id }}-{{ forloop.index }}" 
                 class="tab-panel {% if forloop.first %}is-visible{% endif %}"
                 {% unless forloop.first %}style="display: none;"{% endunless %}>
              
              <div class="product-grid">
                {%- for product in collection.products limit: section.settings.products_count -%}
                  <div class="product-grid__item">
                    {%- include 'product-item', product: product, show_add_to_cart: true -%}
                  </div>
                {%- endfor -%}
              </div>

              {%- if section.settings.show_view_all and collection.products_count > section.settings.products_count -%}
                <div class="section__footer">
                  <a href="{{ collection.url }}" class="button button--primary">{{ 'collection.general.view_all' | t }}</a>
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .tabbed-collections {
    margin-top: 30px;
  }

  .tabs-nav {
    border-bottom: 2px solid #e1e3e4;
    margin-bottom: 30px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .tabs-nav__list {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    white-space: nowrap;
  }

  .tabs-nav__button {
    background: none;
    border: none;
    padding: 12px 20px;
    font-size: 16px;
    font-weight: 600;
    color: #677279;
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tabs-nav__button:hover {
    color: var(--accent-color);
  }

  .tabs-nav__button.is-active {
    color: var(--accent-color);
  }

  .tabs-nav__button.is-active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--accent-color);
  }

  /* Grid Responsivo */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    transition: opacity 0.4s ease;
  }

  @media screen and (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .product-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Transição Suave */
  .tab-panel {
    animation: fadeInTab 0.5s ease forwards;
  }

  @keyframes fadeInTab {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .section__footer {
    text-align: center;
    margin-top: 40px;
  }
</style>

<script>
  (function() {
    function initTabs() {
      const section = document.querySelector('[data-section-id="{{ section.id }}"]');
      if (!section) return;

      const tabButtons = section.querySelectorAll('.tabs-nav__button');
      const tabPanels = section.querySelectorAll('.tab-panel');

      tabButtons.forEach(button => {
        button.addEventListener('click', () => {
          const targetId = button.getAttribute('data-tab-target');
          const targetPanel = section.querySelector(`#${targetId}`);

          if (!targetPanel) return;

          // Desativar todos
          tabButtons.forEach(btn => {
            btn.classList.remove('is-active');
            btn.setAttribute('aria-expanded', 'false');
          });
          tabPanels.forEach(panel => {
            panel.classList.remove('is-visible');
            panel.style.display = 'none';
          });

          // Ativar selecionado
          button.classList.add('is-active');
          button.setAttribute('aria-expanded', 'true');
          targetPanel.style.display = 'block';
          
          // Trigger lazyload if theme uses it
          window.dispatchEvent(new Event('resize'));
        });
      });
    }

    // Inicialização segura
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabs);
    } else {
      initTabs();
    }

    // Suporte ao editor da Shopify
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initTabs();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "!!! Coleções em Abas !!!",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título da Seção",
      "default": "Nossas Coleções"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Produtos por Coleção",
      "min": 4,
      "max": 20,
      "step": 4,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Mostrar botão 'Ver Tudo'",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Coleção",
      "limit": 5,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Coleção"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título da Aba",
          "info": "Se vazio, usa o nome da coleção."
        }
      ]
    }
  ],
  "presets": [
    {
      "category": "Collection",
      "name": "Coleções em Abas",
      "blocks": [
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
