{%- comment -%}
If the product contains the special __gift tag, we prevent it to be completely accessible by redirecting to the home page
{%- endcomment -%}

{%- if product.tags contains '__gift' -%}
  <script>
    window.location.href = '/';
  </script>
{%- else -%}
  {% section 'product-template' %}
  <div style="background:#000;padding:25px;border-radius:16px;color:#fff;font-family:Arial;max-width:700px;margin:30px auto;">

  <p style="color:#00FF7F;font-weight:bold;font-size:14px;margin-bottom:8px;">
    🔥 Mais de 1.284 clientes satisfeitos
  </p>

  <h2 style="margin-bottom:20px;font-size:20px;">
    Avaliações de clientes
  </h2>

  <div style="border-bottom:1px solid #222;padding-bottom:12px;margin-bottom:12px;">
    <strong>Lucas R.</strong> ⭐⭐⭐⭐⭐<br>
    <span style="font-size:14px;color:#ccc;">
      Qualidade absurda, não parece réplica 🔥
    </span>
  </div>

  <div style="border-bottom:1px solid #222;padding-bottom:12px;margin-bottom:12px;">
    <strong>Marcos S.</strong> ⭐⭐⭐⭐⭐<br>
    <span style="font-size:14px;color:#ccc;">
      Chegou antes do prazo, veio tudo certinho
    </span>
  </div>

  <div style="border-bottom:1px solid #222;padding-bottom:12px;margin-bottom:12px;">
    <strong>Felipe A.</strong> ⭐⭐⭐⭐⭐<br>
    <span style="font-size:14px;color:#ccc;">
      Peguei G e ficou perfeita no corpo
    </span>
  </div>

  <div style="border-bottom:1px solid #222;padding-bottom:12px;margin-bottom:12px;">
    <strong>Bruno T.</strong> ⭐⭐⭐⭐⭐<br>
    <span style="font-size:14px;color:#ccc;">
      Já comprei duas vezes, qualidade sempre top
    </span>
  </div>

  <div style="border-bottom:1px solid #222;padding-bottom:12px;margin-bottom:12px;">
    <strong>Rafael M.</strong> ⭐⭐⭐⭐⭐<br>
    <span style="font-size:14px;color:#ccc;">
      Demorou um pouco, mas valeu MUITO a pena
    </span>
  </div>

  <div style="padding-top:5px;">
    <strong>Diego L.</strong> ⭐⭐⭐⭐⭐<br>
    <span style="font-size:14px;color:#ccc;">
      Tecido top e escudo bem feito, pode comprar sem medo
    </span>
  </div>

</div>

  <div id='Areviewsapp' class='page-full'>{%  render 'aliexpress_reviews' , product: product %}</div>					
  <!-- RYVIU APP :: WIDGET -->
  <div class="lt-block-reviews"> 
	<ryviu-widget handle="{{product.handle}}" product_id="{{product.id}}" title_product="{{product.title}}" image_product="{{ product.featured_image.src | img_url: '180x' }}"></ryviu-widget>
  </div>
  <!-- / RYVIU APP -->
  
  {% section 'product-recommendations' %}
  {% section 'static-promotion-list' %}
  {% section 'static-recently-viewed-products' %}

  <script>
    window.ShopifyXR=window.ShopifyXR||function(){(ShopifyXR.q=ShopifyXR.q||[]).push(arguments)};
    ShopifyXR('addModels', {{ product.media | where: 'media_type', 'model' | json }});
  </script>
{%- endif -%}